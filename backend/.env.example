# ── Server ──────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ── Database (PostgreSQL required for persistent hosting) ──
DATABASE_URL="postgresql://user:password@host:5432/aui?sslmode=require"
# DATABASE_URL="file:./dev.db" (SQLite - local dev only, database resets on restart)

# ── FREE AI Providers (get keys from links below) ───
#
# Google Gemini (FREE) → https://aistudio.google.com/apikey
GOOGLE_API_KEY=
#
# Groq (FREE) → https://console.groq.com/keys
GROQ_API_KEY=
#
# Cohere (FREE) → https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
#
# OpenRouter (has FREE models) → https://openrouter.ai/keys
OPENROUTER_API_KEY=
#
# ZenMux (has FREE models) → https://zenmux.ai
ZENMUX_API_KEY=

# ── Provider Defaults ──────────────────────────────
DEFAULT_PROVIDER=google
MAX_RETRIES=3
RETRY_DELAY_MS=1000
REQUEST_TIMEOUT_MS=60000

# ── Rate Limiting ──────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ── File Uploads ───────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
